# ---------------------------------------------------------------------------
# Gradient ADK — environment variable reference
# Copy this file to .env and fill in your values.
# Never commit a .env file containing real secrets.
# ---------------------------------------------------------------------------

# Required: DigitalOcean Gradient Model Access Key.
# Obtain from https://cloud.digitalocean.com/api/tokens
# Used by gradient agent deploy / traces / logs, and by any agent code that
# calls the Gradient API directly.
GRADIENT_API_KEY=your-model-access-key-here

# Optional: override the Gradient API base URL (e.g. for a staging endpoint).
# Defaults to https://api.gradient.digitalocean.com/v1
# GRADIENT_API_BASE=https://api.gradient.digitalocean.com/v1

# Optional: persist the deployed agent ID so traces/logs commands can find it
# automatically without --agent-id.
# GRADIENT_AGENT_ID=ag-xxxxxxxx

# Optional: port the local development server listens on.
# Defaults to 8080.  DigitalOcean App Platform injects PORT automatically.
# PORT=8080
